# Copiar como app.env en esta misma carpeta (assets/env/).
# Copia recomendada:  cp assets/env/app.env.example assets/env/app.env

# none | emailjs | webhook
ERROR_REPORT_PROVIDER=none

# EmailJS — crea una plantilla cuyos campos usen las variables del JSON:
# to_email, subject, message, user_message, technical
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# Opcional si tu cuenta EmailJS requiere token de servidor
EMAILJS_PRIVATE_KEY=

# Backend propio que reciba JSON y mande correo (SendGrid, SES, etc.)
ERROR_REPORT_URL=
ERROR_REPORT_BEARER_TOKEN=
